        "/api/published/{id}/broadcast/audio": {
            "post": {
                "tags": [
                    "Broadcasts"
                ],
                "summary": "Generate audio broadcast for a published article using ElevenLabs",
                "operationId": "f9d4954963c9279c81cf74dd84edd6f5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "voice_id": {
                                        "type": "string",
                                        "example": "pNInz6obpgDQGcFmaJgB"
                                    },
                                    "model_id": {
                                        "type": "string",
                                        "example": "eleven_multilingual_v2"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Audio generated (or fetched from cache)"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "500": {
                        "description": "ElevenLabs API error"
                    }
                }
            }
