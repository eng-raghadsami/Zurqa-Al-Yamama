                        "description": "Published content deleted successfully"
                    }
                }
            }
        },
        "/api/terms": {
            "get": {
                "tags": [
                    "Terms"
                ],
                "summary": "Get all media terms",
                "operationId": "738fc98f4c919c742ab3280b8f378616",
                "responses": {
                    "200": {
                        "description": "List of terms"
                    }
                }
            },
            "post": {
                "tags": [
                    "Terms"
                ],
                "summary": "Create a media term",
                "operationId": "9f08143164ba4f23caffa7edd937d10d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "word",
                                    "meaning"
                                ],
                                "properties": {
                                    "word": {
                                        "type": "string",
                                        "example": "مصدر مطلع"
                                    },
                                    "meaning": {
                                        "type": "string",
                                        "example": "تعبير يستخدم للإشارة إلى شخص لديه معلومات عن الموضوع دون ذكر اسمه."
                                    },
                                    "category": {
                                        "type": "string",
                                        "example": "مصطلحات الأخبار"
                                    },
                                    "is_active": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Term created successfully"
                    }
                }
            }
        },
