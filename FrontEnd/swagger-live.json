    "paths": {
        "/api/contents": {
            "get": {
                "tags": [
                    "Contents"
                ],
                "summary": "Get all contents",
                "operationId": "794455e2ae76f0d16390c0d65573e5cf",
                "responses": {
                    "200": {
                        "description": "List of contents"
                    }
                }
            },
            "post": {
                "tags": [
                    "Contents"
                ],
                "summary": "Create a new content",
                "operationId": "28ee10be1de60782f9ecf184dbf4c4cf",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "New Content"
                                    },
                                    "body": {
                                        "type": "string",
                                        "example": "Content details"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Content created successfully"
                    },
                    "422": {
                        "description": "Validation or create error"
                    }
                }
            }
        },
        "/api/contents/{id}": {
            "get": {
                "tags": [
                    "Contents"
                ],
                "summary": "Get a single content",
                "operationId": "1860dae49ccefc184b1d6d84b27039ae",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Content details"
                    }
                }
            },
            "put": {
                "tags": [
                    "Contents"
                ],
                "summary": "Update a content",
                "operationId": "37af1b4468fb29809a50b7567eebcaec",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Updated Content Title"
                                    },
                                    "body": {
                                        "type": "string",
                                        "example": "Updated content details"
                                    },
                                    "category_id": {
                                        "type": "integer",
                                        "example": 3
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "approved"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Content updated successfully"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Contents"
                ],
                "summary": "Delete a content",
                "operationId": "269ed286f9e98033c9e8ecafb43d005d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Content deleted successfully"
                    }
                }
            }
        },
        "/api/images/analyze": {
            "post": {
                "tags": [
                    "Images"
                ],
                "summary": "Analyze an image for safety",
                "operationId": "0f83a75a8d1dfbb660ebdbdd28598834",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "image"
                                ],
                                "properties": {
                                    "image": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful analysis",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "racism": {
                                            "type": "integer"
                                        },
                                        "violence": {
                                            "type": "integer"
                                        },
                                        "sensitive_content": {
                                            "type": "integer"
                                        },
                                        "blood": {
                                            "type": "integer"
                                        },
                                        "ai_generated": {
                                            "type": "boolean"
                                        },
                                        "forged": {
                                            "type": "boolean"
                                        },
                                        "ai_generated_percentage": {
                                            "type": "integer"
                                        },
                                        "forged_percentage": {
                                            "type": "integer"
                                        },
                                        "description": {
                                            "type": "string"
                                        },
                                        "actions": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        },
                                        "criteria_scores": {
                                            "type": "object"
                                        },
                                        "errors": {
                                            "type": "object"
                                        },
                                        "blurred_image_url": {
                                            "type": "string",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/published": {
            "get": {
                "tags": [
                    "Published"
                ],
                "summary": "Get all published contents",
