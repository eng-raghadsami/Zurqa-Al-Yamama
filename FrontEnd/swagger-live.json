                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Published content updated successfully"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Published"
                ],
                "summary": "Delete a published content",
                "operationId": "1f68a7be8a4669bca7459a5a44f2ddc6",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
